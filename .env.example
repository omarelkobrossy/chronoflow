# Environment variables for the Adaptive ML Trading System
# Copy this file to .env and fill in real values.
# NEVER commit .env or any file containing real credentials.

# ── AWS Batch (FAPT distributed optimization) ──────────────────────────────
# Your AWS Batch job queue name
AWS_BATCH_JOB_QUEUE=MLTraderQueue

# Full ARN of your AWS Batch job definition
# Format: arn:aws:batch:<region>:<account-id>:job-definition/<name>:<revision>
AWS_BATCH_JOB_DEFINITION=arn:aws:batch:us-east-1:YOUR_ACCOUNT_ID:job-definition/YOUR_JOB_DEF_NAME:1

# ── Exchange credentials ────────────────────────────────────────────────────
# Binance credentials are loaded from settings/binance_api_key.json (gitignored).
# Copy settings/binance_api_key.example.json to settings/binance_api_key.json
# and fill in your key and secret. Do not commit that file.

# Coinbase CDP credentials are loaded from settings/cdp_api_key.json (gitignored).
# Obtain from Coinbase Developer Platform and place in that file.
